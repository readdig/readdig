NODE_ENV=development

API_PORT=8000
API_HOST=localhost

PRODUCT_URL=https://your-domain.com
PRODUCT_NAME=Readdig.com

USER_AGENT=ReaddigBot/1.0 (https://www.readdig.com)

STATIC_PATH=./static

# Note: For Docker deployment, CACHE_URL and DATABASE_URL are configured
# in docker-compose.yml using internal service names (cache, database)
CACHE_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:password@localhost:5432/readdig_dev

JWT_SECRET=

SENTRY_DSN=

EMAIL_BACKEND=
EMAIL_SENDER_SUPPORT_NAME=
EMAIL_SENDER_SUPPORT_EMAIL=
EMAIL_SENDGRID_SECRET=

# Cloudflare worker proxy
# https://<your-cloudflare-worker>.workers.dev
CLOUDFLARE_PROXY_URL=
CLOUDFLARE_PROXY_SECRET=

# V2EX API v2 (auto-fetch topic replies for v2ex feeds)
# Personal Access Token from https://www.v2ex.com/settings/tokens
V2EX_TOKEN=
# Base URL only; the /api/v2 path is appended automatically
V2EX_BASE_URL=https://www.v2ex.com
# Minutes to cache replies in DB before re-fetching (limits API usage; 600 req/hour/IP)
V2EX_REPLIES_TTL=30

# Hacker News comments (auto-fetch story comments for news.ycombinator.com/item links)
# No credentials needed; set HN_BASE_URL to enable (leave empty to disable).
# Base URL only; the /api/v1 path is appended automatically.
# Recommended value: https://hn.algolia.com (Algolia HN Search API)
HN_BASE_URL=https://hn.algolia.com
# Minutes to cache comments in DB before re-fetching (default 30 if unset)
HN_COMMENTS_TTL=30

# Paddle
PADDLE_PUBLIC_KEY=
PADDLE_API_URL=
PADDLE_VENDOR_ID=
PADDLE_VENDOR_AUTH_CODE=

# Gravatar CDN (leave empty to use default gravatar.com)
GRAVATAR_CDN=

# Free Mode - enabled by default. Set to 'false' to enable paid plans
# FREE_MODE=false